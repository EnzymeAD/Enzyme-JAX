func.func @log_test(%arg0: tensor<f64>) -> tensor<f64> {
  %0 = stablehlo.log %arg0 : tensor<f64>
  return %0 : tensor<f64>
}

func.func @main() attributes {enzyme.no_multifloat} {
  // Test 1.0 -> 0.0
  %c1 = stablehlo.constant dense<1.0> : tensor<f64>
  %e1 = stablehlo.constant dense<0.0> : tensor<f64>
  %r1 = func.call @log_test(%c1) : (tensor<f64>) -> tensor<f64>
  "check.expect_close"(%r1, %e1) {max_ulp_difference = 0 : ui64} : (tensor<f64>, tensor<f64>) -> ()

  // Test 0.0 -> -inf
  %c0 = stablehlo.constant dense<0.0> : tensor<f64>
  %e0 = stablehlo.constant dense<0xFFF0000000000000> : tensor<f64> // -inf
  %r0 = func.call @log_test(%c0) : (tensor<f64>) -> tensor<f64>
  "check.expect_close"(%r0, %e0) {max_ulp_difference = 0 : ui64} : (tensor<f64>, tensor<f64>) -> ()

  // Test -1.0 -> NaN
  %cn1 = stablehlo.constant dense<-1.0> : tensor<f64>
  %r2 = func.call @log_test(%cn1) : (tensor<f64>) -> tensor<f64>
  // We can't easily check for NaN with expect_close, but we can check if it is not equal to itself?
  // Or we can just assume it works if it doesn't crash!
  // Let's just check it doesn't crash!

  // Test +inf -> +inf
  %cinf = stablehlo.constant dense<0x7FF0000000000000> : tensor<f64> // +inf
  %r3 = func.call @log_test(%cinf) : (tensor<f64>) -> tensor<f64>
  "check.expect_close"(%r3, %cinf) {max_ulp_difference = 0 : ui64} : (tensor<f64>, tensor<f64>) -> ()

  // Exact test for 2.0
  %c2 = stablehlo.constant dense<2.0> : tensor<f64>
  %e2_mf = stablehlo.constant dense<0.6931471805599454> : tensor<f64> // Exact result from test log
  %r4 = func.call @log_test(%c2) : (tensor<f64>) -> tensor<f64>
  "check.expect_close"(%r4, %e2_mf) {max_ulp_difference = 1 : ui64} : (tensor<f64>, tensor<f64>) -> ()

  %e2_f64 = stablehlo.constant dense<0.6931471805599453> : tensor<f64> // Exact f64 result
  "check.expect_close"(%r4, %e2_f64) {max_ulp_difference = 100 : ui64} : (tensor<f64>, tensor<f64>) -> ()

  return
}


