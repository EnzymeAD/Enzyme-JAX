func.func @divide(%arg0: tensor<8xf64>, %arg1: tensor<8xf64>) -> tensor<8xf64> {
  %0 = stablehlo.divide %arg0, %arg1 : tensor<8xf64>
  return %0 : tensor<8xf64>
}

