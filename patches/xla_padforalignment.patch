   std::string hloCustomCall = absl::Substitute(
       R"(
-HloModule TestModule, entry_computation_layout={(s8[32,1,3,3,32]{4,3,2,1,0},f32[$0]{0})->(s8[32,1,3,3,32]{4,3,2,1,0},f32[$0]{0})}
