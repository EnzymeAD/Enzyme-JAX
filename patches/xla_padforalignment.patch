+#include "tsl/platform/errors.h"
+
+namespace xla {
+namespace {
+
+class AlignmentHandler {
+ public:
+  explicit AlignmentHandler(HloComputation* comp) : comp_(comp) {}
+
+  static std::vector<int64_t> GetPaddingAmounts(const Shape& shape) {
+    if (!shape.IsArray()) return {};
+    int64_t rank = shape.rank();
+    std::vector<int64_t> padding(rank, 0);
+    if (rank == 0) return padding;
+
+    std::vector<int64_t> non_singleton_dims;
+    for (int64_t i = 0; i < rank; ++i) {
+      if (shape.dimensions(i) > 1) non_singleton_dims.push_back(i);
+    }
+
+    int64_t ns_rank = non_singleton_dims.size();
+    for (int64_t i = std::max<int64_t>(0, ns_rank - 2); i < ns_rank; ++i) {
+      int64_t dim = non_singleton_dims[i];
+      int64_t size = shape.dimensions(dim);
+      if (size >= 64 && size % 128 != 0) {
+        padding[dim] = ((size + 127) / 128 * 128) - size;
+      }
+    }
+    return padding;
+  }
+
+  static bool NeedsPadding(const Shape& shape) {
+    for (int64_t p : GetPaddingAmounts(shape)) {
+      if (p > 0) return true;
+    }
+    return false;
+  }
+
+  static Shape GetAlignedShape(const Shape& shape) {
+    auto padding = GetPaddingAmounts(shape);
+    Shape aligned_shape = shape;
+    for (int64_t i = 0; i < shape.rank(); ++i) {
+      aligned_shape.set_dimensions(i, shape.dimensions(i) + padding[i]);
+    }
+    return aligned_shape;
+  }
+
+  HloInstruction* GetOrCreatePadOp(HloInstruction* inst) {
+    if (padded_values_.contains(inst)) return padded_values_[inst];
+    if (!NeedsPadding(inst->shape())) return inst;
+
+    auto padding = GetPaddingAmounts(inst->shape());
+    PaddingConfig config;
+    for (int64_t p : padding) {
+      auto* dims = config.add_dimensions();
+      dims->set_edge_padding_low(0);
+      dims->set_edge_padding_high(p);
+      dims->set_interior_padding(0);
+    }
+
+    Shape padded_shape = GetAlignedShape(inst->shape());
+    HloInstruction* zero = comp_->AddInstruction(
+        HloInstruction::CreateConstant(
+            LiteralUtil::Zero(inst->shape().element_type())));
+
+    HloInstruction* pad_op = comp_->AddInstruction(
+        HloInstruction::CreatePad(padded_shape, inst, zero, config));
+
+    padded_values_[inst] = pad_op;
+    return pad_op;
+  }
+
+  HloInstruction* GetOrCreateSliceOp(HloInstruction* padded_inst,
+                                     const Shape& original_shape) {
+    if (ShapeUtil::Compatible(padded_inst->shape(), original_shape))
+      return padded_inst;
+
+    std::vector<int64_t> starts(original_shape.rank(), 0);
+    std::vector<int64_t> strides(original_shape.rank(), 1);
+    std::vector<int64_t> limits(original_shape.dimensions().begin(),
+                                original_shape.dimensions().end());
+
+    return comp_->AddInstruction(HloInstruction::CreateSlice(
+        original_shape, padded_inst, starts, limits, strides));
+  }
+
+  bool HandleElementwise(HloInstruction* inst) {
+    std::vector<HloInstruction*> new_operands;
+    for (auto* operand : inst->operands()) {
+      new_operands.push_back(GetOrCreatePadOp(operand));
+    }
+
+    Shape new_shape = GetAlignedShape(inst->shape());
+    HloInstruction* new_inst = comp_->AddInstruction(
+        inst->CloneWithNewOperands(new_shape, new_operands));
+
+    padded_values_[inst] = new_inst;
+    return true;
+  }
+
+  bool HandleDot(HloInstruction* inst) {
+    HloInstruction* lhs = GetOrCreatePadOp(inst->mutable_operand(0));
+    HloInstruction* rhs = GetOrCreatePadOp(inst->mutable_operand(1));
+
+    Shape new_shape = GetAlignedShape(inst->shape());
+    HloInstruction* new_dot = comp_->AddInstruction(
+        HloInstruction::CreateDot(new_shape, lhs, rhs,
+                                  inst->dot_dimension_numbers(),
+                                  inst->precision_config()));
+    padded_values_[inst] = new_dot;
+    return true;
+  }
+
+  absl::Status ReplacePaddedUses() {
+    for (auto& [orig, padded] : padded_values_) {
+      if (orig == padded) continue;
+
+      HloInstruction* sliced = GetOrCreateSliceOp(padded, orig->shape());
+      TF_RETURN_IF_ERROR(orig->ReplaceAllUsesWith(sliced));
+    }
+    return absl::OkStatus();
+  }
+
+ private:
+  HloComputation* comp_;
+  absl::flat_hash_map<HloInstruction*, HloInstruction*> padded_values_;
+};
+
+}  // namespace
+
+absl::StatusOr<bool> HloPadForAlignment::RunImpl(
+    HloModule* module,
+    const absl::flat_hash_set<absl::string_view>& execution_threads) {
+  bool changed = false;
+  for (auto* comp : module->computations(execution_threads)) {
+    AlignmentHandler handler(comp);
+
+    for (auto* inst : comp->MakeInstructionPostOrder()) {
+      if (!AlignmentHandler::NeedsPadding(inst->shape())) {
+        continue;
+      }
+
+      bool handled = false;
+      if (HloOpcodeIsBinaryElementwise(inst->opcode()) ||
+          HloOpcodeIsUnaryElementwise(inst->opcode())) {
+        handled = handler.HandleElementwise(inst);
+      } else if (inst->opcode() == HloOpcode::kDot) {
+        handled = handler.HandleDot(inst);
+      }
+
+      if (handled) changed = true;
+    }
+
+    if (changed) {
+      TF_RETURN_IF_ERROR(handler.ReplacePaddedUses());
+    }
+  }
+  return changed;
+}
+
+}  // namespace xla
