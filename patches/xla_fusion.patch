+    // Heuristic: Do not fuse a dynamic-slice or concatenate computation into a
+    // loop consumer if it would duplicate the dynamic-slice/concatenate, 
+    // because GpuHloCostAnalysis under-costs the index arithmetic/branch latency.
+    if (producer->opcode() == HloOpcode::kDynamicSlice ||
+        producer->opcode() == HloOpcode::kConcatenate) {
+      bool would_duplicate =
+          !(producer->users().size() == 1 && consumer->IsUserOf(producer));
+      if (would_duplicate) {
+        return FusionDecision::Forbid(
+            "fusion of dynamic-slice/concatenate would duplicate index arithmetic/branching cost");
+      }
+    }
