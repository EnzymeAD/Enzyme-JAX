+
+namespace xla {
+
+// An HLO pass that recognizes overlapping slices and pads being combined via
+// elementwise operations and transforms them into reduce_window operations.
+class RecognizeReduceWindow : public HloModulePass {
+ public:
+  RecognizeReduceWindow() = default;
+
+  absl::string_view name() const override { return "recognize-reduce-window"; }
+
+ protected:
+  absl::StatusOr<bool> RunImpl(
+      HloModule* module,
+      const absl::flat_hash_set<absl::string_view>& execution_threads) override;
+};
+
