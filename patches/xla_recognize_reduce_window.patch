+#ifndef XLA_HLO_TRANSFORMS_SIMPLIFIERS_RECOGNIZE_REDUCE_WINDOW_H_
+#define XLA_HLO_TRANSFORMS_SIMPLIFIERS_RECOGNIZE_REDUCE_WINDOW_H_
+
+#include "absl/container/flat_hash_set.h"
+#include "absl/status/statusor.h"
